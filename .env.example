# ShaneBrain MCP Server — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── Required ─────────────────────────────────────────────────────────────────

# Gmail app password for shanebrain_send_email and shanebrain_reply_email
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# ─── Optional (defaults shown) ────────────────────────────────────────────────

# Ollama host and default model for local inference / RAG chat
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=shanebrain-3b:latest

# MCP server port (must match how claude mcp add was registered)
MCP_PORT=8100

# Path to Google Calendar OAuth token inside the container
GCAL_TOKEN_PATH=/app/gcal_token.json

# Google Calendar ID ("primary" uses your default calendar)
GCAL_CALENDAR_ID=primary

# Planning system directory inside the container
# Mount the host path as a volume so plans survive container restarts
PLANNING_DIR=/app/planning
