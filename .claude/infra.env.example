# ShaneBrain Infrastructure Cutover Primitive
# =============================================
#
# This file holds the variables that flip when the active Weaviate / MCP host
# changes (e.g. Pi 5 -> neworleans during Phase 3 migration).
#
# Workflow:
#   1. Copy this file to .claude/infra.env (gitignored — per-host values)
#   2. Source it before running tools, scripts, or docker-compose:
#        set -a; source .claude/infra.env; set +a
#      Or wire docker-compose via env_file: .claude/infra.env (separate change).
#   3. Cutover = edit one file (this one) and re-source. No code changes.
#
# Anything NOT in this file should NOT differ between hosts. If a setting only
# differs at cutover, it belongs here. If a setting is host-invariant (e.g.
# OLLAMA_MODEL, MCP_PORT), keep it in .env / docker-compose.yml.

# ─── Active deployment target ────────────────────────────────────────────────
# Label only — used by diff scripts and logs. Set to "pi" or "neworleans".
SHANEBRAIN_ACTIVE_HOST=pi

# ─── Weaviate location ───────────────────────────────────────────────────────
# Pi default: localhost (Weaviate co-located with MCP container)
# neworleans: <neworleans-tailscale-ip> (Weaviate moves; MCP can stay or follow)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# ─── Ollama location ─────────────────────────────────────────────────────────
# Pi default: localhost:11434
# neworleans (if MCP follows Weaviate): http://<pi-tailscale-ip>:11434
# Ollama stays on Pi for the foreseeable future — only the *client* side flips.
OLLAMA_HOST=http://localhost:11434

# ─── Replica target (Phase 3 read-replica) ───────────────────────────────────
# Used by scripts/replica_sync.sh to call the primary's backup API and restore
# locally. On the Pi after cutover this points at neworleans.
WEAVIATE_REPLICA_PRIMARY_HOST=
WEAVIATE_REPLICA_PRIMARY_PORT=8080
